# ShiftProof environment variables
# Copy the relevant values into Railway (and preview environments).
# Never commit a filled-in .env file — only this example is tracked.

# --- Supabase (public, safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase (server-only, NEVER expose to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database connection string (server-only) ---
# Use the pooled connection string from Supabase for serverless/edge runtimes.
DATABASE_URL=postgresql://postgres:your-password@your-project-ref.supabase.co:5432/postgres

# --- Railway ---
RAILWAY_ENVIRONMENT_NAME=production

# --- Application ---
APP_BASE_URL=https://shiftproof.up.railway.app

# --- Email (Resend), server-only ---
# Digest emails are sent via Resend. Leave unset to keep in-app-only (no email).
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=ShiftProof <notifications@your-domain.com>

# --- Digest cron trigger (server-only) ---
# Shared secret required by POST /api/cron/due-digest. Unset ⇒ endpoint refuses all.
CRON_SECRET=your-long-random-secret
